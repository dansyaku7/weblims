// Made by SyK
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

model Riwayat {
  id        String   @id @default(cuid())
  tipe      String
  nomor     String   @unique
  judul     String
  dataForm  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role      Role     @relation(fields: [roleId], references: [id])
  roleId    Int
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique 
  users User[]
}

model Fpps {
  id              Int       @id @default(autoincrement())
  nomorFpps       String    @unique
  nomorQuotation  String?
  petugas         Json
  namaPelanggan   String?
  alamatPelanggan String?
  noTelp          String?
  tanggalMasuk    String?
  kegiatan        String?
  namaPpic        String?
  emailPpic       String?
  status          Status    @default(pendaftaran)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  rincian         Rincian[]
}

model Rincian {
  id        Int     @id @default(autoincrement())
  idRincian String
  area      String?
  matriks   String?
  parameter String?
  regulasi  String?
  metode    String?
  fpps      Fpps    @relation(fields: [fppsId], references: [id])
  fppsId    Int
}

model Report {
  id              String   @id
  coverData       Json
  activeTemplates Json
  status          Status   @default(pendaftaran)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum Status {
  pendaftaran
  penyuratan
  sampling
  analisis
  sertifikat
  selesai
}

model RiwayatDokumen {
  id        String   @id @default(cuid())
  tipe      String   
  nomor     String   @unique
  judul     String
  tanggal   DateTime
  dataForm  Json     
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SensorLog {
  id           Int      @id @default(autoincrement())
  apiMentah    Int
  gasMentah    Int
  suhuMentah   Float
  maGas        Int
  maSuhu       Float
  rorSuhu      Float
  statusSistem String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}